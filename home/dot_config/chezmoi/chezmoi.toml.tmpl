# Managed by chezmoi (template)
# This file will be written to ~/.config/chezmoi/chezmoi.toml

{{ $system := "desktop" }}
{{- if eq .chezmoi.os "linux" }}
  {{- /* Auto-detect: Raspberry Pi first, then server if hostname contains "server", otherwise desktop */ -}}
  {{- $osID := .chezmoi.osRelease.id -}}
  {{- $osName := "" -}}
  {{- $osPrettyName := "" -}}
  {{- if hasKey .chezmoi.osRelease "name" -}}
    {{- $osName = .chezmoi.osRelease.name -}}
  {{- end -}}
  {{- if hasKey .chezmoi.osRelease "prettyName" -}}
    {{- $osPrettyName = .chezmoi.osRelease.prettyName -}}
  {{- end -}}
  {{- if or (eq $osID "raspbian") (contains "raspberry" (lower $osName)) (contains "raspberry" (lower $osPrettyName)) (contains "raspberrypi" .chezmoi.hostname) (contains "raspi" .chezmoi.hostname) -}}
    {{- $system = "raspberrypi" -}}
  {{- else if contains "server" .chezmoi.hostname -}}
    {{- $system = "server" -}}
  {{- else -}}
    {{- $system = "desktop" -}}
  {{- end -}}
{{- end }}

# Global config
[config]
# color = true
# pager = ""
# umask = "022"

{{- if eq .chezmoi.os "darwin" }}

# macOS: use VS Code as editor
[edit]
command = "code"
{{- end }}

# Bitwarden integration
[bitwarden]
unlock = "auto"

# Data available to templates (used by run_once_install.sh.tmpl)
[data]
system = "{{ $system }}"
