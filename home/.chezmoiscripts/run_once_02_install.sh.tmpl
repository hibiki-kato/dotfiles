#!/usr/bin/env zsh
# Managed by chezmoi. Do not edit directly. Update via chezmoi, using OS/host-specific partitioning when needed.
set -euo pipefail

echo "=== Starting bootstrap for {{ .chezmoi.os }} ==="

{{- $src := .chezmoi.sourceDir }}
{{- $install := printf "%s/../install" $src }}
{{- $system := "server" }}
{{- if eq .chezmoi.os "linux" }}
  {{- $osID := .chezmoi.osRelease.id }}
  {{- $osName := "" }}
  {{- $osPrettyName := "" }}
  {{- if hasKey .chezmoi.osRelease "name" }}
    {{- $osName = .chezmoi.osRelease.name }}
  {{- end }}
  {{- if hasKey .chezmoi.osRelease "prettyName" }}
    {{- $osPrettyName = .chezmoi.osRelease.prettyName }}
  {{- end }}
  {{- if or (eq $osID "raspbian") (contains "raspberry" (lower $osName)) (contains "raspberry" (lower $osPrettyName)) }}
    {{- $system = "raspberrypi" }}
  {{- end }}
{{- end }}

is_raspberry_pi() {
  [ -r /etc/os-release ] && grep -Eqi '^(ID=raspbian|ID_LIKE=.*raspbian|PRETTY_NAME=.*raspberry pi)' /etc/os-release && return 0
  return 1
}

detect_ubuntu_system() {
  if command -v dpkg-query >/dev/null 2>&1 &&
    dpkg-query -W -f='${Status}\n' \
      ubuntu-desktop ubuntu-desktop-minimal xubuntu-desktop kubuntu-desktop \
      lubuntu-desktop ubuntu-mate-desktop 2>/dev/null |
      grep -q 'install ok installed'; then
    printf '%s\n' "desktop"
  elif command -v systemctl >/dev/null 2>&1 &&
    [ "$(systemctl get-default 2>/dev/null)" = "graphical.target" ] &&
    systemctl list-unit-files 'display-manager.service' 2>/dev/null | grep -q 'display-manager.service'; then
    printf '%s\n' "desktop"
  else
    printf '%s\n' "server"
  fi
}

select_linux_system() {
  case "${CHEZMOI_INSTALL_PROFILE:-}" in
    desktop|server|raspberrypi|raspi)
      [ "$CHEZMOI_INSTALL_PROFILE" = "raspi" ] && printf '%s\n' "raspberrypi" || printf '%s\n' "$CHEZMOI_INSTALL_PROFILE"
      return 0
      ;;
    "")
      ;;
    *)
      echo "Unsupported CHEZMOI_INSTALL_PROFILE: $CHEZMOI_INSTALL_PROFILE" >&2
      exit 1
      ;;
  esac

  if is_raspberry_pi; then
    printf '%s\n' "raspberrypi"
  else
    detect_ubuntu_system
  fi
}

# Run all *.sh in a directory (lexicographic order: 001-*, 002-*, ...)
run_all() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  # shellcheck disable=SC2045
  for f in $(LC_ALL=C ls -1 "$dir"/*.sh 2>/dev/null | sort); do
    [ -f "$f" ] || continue
    case "$(basename "$f")" in
      01-prereqs.sh)
        echo "Skipping obsolete installer: $f"
        continue
        ;;
    esac
    [ -x "$f" ] || chmod +x "$f" || true
    echo "→ Running: $f"
    "$f"
  done
}

{{ if eq .chezmoi.os "darwin" -}}
# macOS installers
run_all "{{ $install }}/macos"

{{ else if eq .chezmoi.os "linux" -}}
system="{{ $system }}"
system="$(select_linux_system)"
echo "Selected install profile: $system"

if [ "$system" = "raspberrypi" ]; then
  # Raspberry Pi lightweight installers
  run_all "{{ $install }}/raspberrypi"
elif [ "$system" = "server" ]; then
  # Ubuntu common prereqs
  run_all "{{ $install }}/ubuntu/common"
  # Ubuntu server
  run_all "{{ $install }}/ubuntu/server"
else
  # Ubuntu common prereqs
  run_all "{{ $install }}/ubuntu/common"
  # Ubuntu desktop
  run_all "{{ $install }}/ubuntu/desktop"
fi

{{ else -}}
echo "⚠ Unsupported OS: {{ .chezmoi.os }}"
exit 1
{{ end -}}

echo "=== Bootstrap completed for {{ .chezmoi.os }} ==="
