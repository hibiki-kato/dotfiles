#!/usr/bin/env zsh
set -euo pipefail

echo "=== Starting bootstrap for {{ .chezmoi.os }} ==="

{{- $src := .chezmoi.sourceDir }}
{{- $install := printf "%s/../install" $src }}
{{- $system := "desktop" }}
{{- if eq .chezmoi.os "linux" }}
  {{- $osID := .chezmoi.osRelease.id }}
  {{- $osName := "" }}
  {{- $osPrettyName := "" }}
  {{- if hasKey .chezmoi.osRelease "name" }}
    {{- $osName = .chezmoi.osRelease.name }}
  {{- end }}
  {{- if hasKey .chezmoi.osRelease "prettyName" }}
    {{- $osPrettyName = .chezmoi.osRelease.prettyName }}
  {{- end }}
  {{- if or (eq $osID "raspbian") (contains "raspberry" (lower $osName)) (contains "raspberry" (lower $osPrettyName)) (contains "raspberrypi" .chezmoi.hostname) (contains "raspi" .chezmoi.hostname) }}
    {{- $system = "raspberrypi" }}
  {{- else if hasKey . "system" }}
    {{- $system = .system }}
  {{- else if contains "server" .chezmoi.hostname }}
    {{- $system = "server" }}
  {{- end }}
{{- else if hasKey . "system" }}
  {{- $system = .system }}
{{- end }}

is_raspberry_pi() {
  [ -r /proc/device-tree/model ] && grep -qi 'raspberry pi' /proc/device-tree/model && return 0
  [ -r /etc/os-release ] && grep -qi 'raspberry pi' /etc/os-release && return 0
  return 1
}

# Run all *.sh in a directory (lexicographic order: 001-*, 002-*, ...)
run_all() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  # shellcheck disable=SC2045
  for f in $(LC_ALL=C ls -1 "$dir"/*.sh 2>/dev/null | sort); do
    [ -f "$f" ] || continue
    [ -x "$f" ] || chmod +x "$f" || true
    echo "→ Running: $(basename "$f")"
    "$f"
  done
}

{{ if eq .chezmoi.os "darwin" -}}
# macOS installers
run_all "{{ $install }}/macos"

{{ else if eq .chezmoi.os "linux" -}}
system="{{ $system }}"
if is_raspberry_pi; then
  system="raspberrypi"
fi

if [ "$system" = "raspberrypi" ]; then
  # Raspberry Pi lightweight installers
  run_all "{{ $install }}/raspberrypi"
elif [ "$system" = "server" ]; then
  # Ubuntu common prereqs
  run_all "{{ $install }}/ubuntu/common"
  # Ubuntu server
  run_all "{{ $install }}/ubuntu/server"
else
  # Ubuntu common prereqs
  run_all "{{ $install }}/ubuntu/common"
  # Ubuntu desktop
  run_all "{{ $install }}/ubuntu/desktop"
fi

{{ else -}}
echo "⚠ Unsupported OS: {{ .chezmoi.os }}"
exit 1
{{ end -}}

echo "=== Bootstrap completed for {{ .chezmoi.os }} ==="
