# Managed by chezmoi. Do not edit directly. Update via chezmoi, using OS/host-specific partitioning when needed.
# Common settings (all platforms)
{{- $isDarwin := eq .chezmoi.os "darwin" }}
{{- $isLinux := eq .chezmoi.os "linux" }}
{{- $linuxProfile := "desktop" }}
{{- if $isLinux }}
  {{- $osID := .chezmoi.osRelease.id }}
  {{- $osName := "" }}
  {{- $osPrettyName := "" }}
  {{- if hasKey .chezmoi.osRelease "name" }}
    {{- $osName = .chezmoi.osRelease.name }}
  {{- end }}
  {{- if hasKey .chezmoi.osRelease "prettyName" }}
    {{- $osPrettyName = .chezmoi.osRelease.prettyName }}
  {{- end }}
  {{- $isRaspberryPiOS := or (eq $osID "raspbian") (contains "raspberry" (lower $osName)) (contains "raspberry" (lower $osPrettyName)) }}
  {{- if $isRaspberryPiOS }}
    {{- $linuxProfile = "raspberrypi" }}
  {{- else }}
    {{- $linuxProfile = output "sh" "-c" "if command -v dpkg-query >/dev/null 2>&1 && dpkg-query -W -f='${Status}\\n' ubuntu-desktop ubuntu-desktop-minimal xubuntu-desktop kubuntu-desktop lubuntu-desktop ubuntu-mate-desktop 2>/dev/null | grep -q 'install ok installed'; then printf desktop; elif command -v systemctl >/dev/null 2>&1 && [ \"$(systemctl get-default 2>/dev/null)\" = graphical.target ] && systemctl list-unit-files display-manager.service 2>/dev/null | grep -q display-manager.service; then printf desktop; else printf server; fi" }}
  {{- end }}
{{- end }}

# Lean/Elan
export PATH="$HOME/.elan/bin:$PATH"
# Local user binaries (e.g., uv installs here)
export PATH="$HOME/.local/bin:$PATH"
# npm global packages (codex, openclaw, gemini, etc.)
export PATH="$HOME/.npm-global/bin:$PATH"
# Juliaup
export PATH="$HOME/.juliaup/bin:$PATH"
# Rust/Cargo
if [ -f "$HOME/.cargo/env" ]; then
    source "$HOME/.cargo/env"
else
    export PATH="$HOME/.cargo/bin:$PATH"
fi

# Safer rm when a trash command is available
if command -v trash >/dev/null 2>&1; then
    alias rm='trash'
elif command -v trash-put >/dev/null 2>&1; then
    alias rm='trash-put'
fi

# Editor aliases
if command -v nvim >/dev/null 2>&1; then
    alias vi='nvim'
    alias vim='nvim'
    alias view='nvim -R'
fi

{{ if and $isLinux (eq $linuxProfile "desktop") -}}
# Ollama shortcuts (Ubuntu desktop only)
unalias gemma 2>/dev/null || true
gemma() {
    local started_ollama=0
    local ollama_pid=""
    local exit_code=0

    if ! curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
        ollama serve >/tmp/ollama-gemma.log 2>&1 &
        ollama_pid=$!
        started_ollama=1

        for _ in {1..50}; do
            if curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
                break
            fi
            sleep 0.2
        done

        if ! curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
            echo "Failed to start ollama serve. See /tmp/ollama-gemma.log" >&2
            kill "$ollama_pid" >/dev/null 2>&1 || true
            wait "$ollama_pid" >/dev/null 2>&1 || true
            return 1
        fi
    fi

    ollama run gemma4 --experimental --experimental-websearch "$@"
    exit_code=$?

    if [ "$started_ollama" -eq 1 ]; then
        ollama stop gemma4 >/dev/null 2>&1 || true
        kill "$ollama_pid" >/dev/null 2>&1 || true
        wait "$ollama_pid" >/dev/null 2>&1 || true
    fi

    return "$exit_code"
}
{{ end -}}

# Julia thread count
export JULIA_NUM_THREADS=auto

# Homebrew C/C++ compiler
export HOMEBREW_CC=gcc
export HOMEBREW_CXX=g++

{{ if $isDarwin -}}
# === macOS specific settings ===

# Miniforge (Conda-forge) initialization
if [ -x "/opt/homebrew/Caskroom/miniforge/base/bin/conda" ]; then
    __conda_setup="$('/opt/homebrew/Caskroom/miniforge/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        export PATH="/opt/homebrew/Caskroom/miniforge/base/bin:$PATH"
    fi
    unset __conda_setup
elif [ -f "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh" ]; then
    . "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"
else
    export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
fi
export "PATH=/usr/local/bin:$PATH"

# LAPACK (Homebrew)
export LDFLAGS="-L/opt/homebrew/opt/lapack/lib"
export CPPFLAGS="-I/opt/homebrew/opt/lapack/include"

# OS name
export OS_NAME=Darwin

# Docker settings
export DOCKER_BUILDKIT=1

# OpenMP thread count
export OMP_NUM_THREADS=10

# Flutter path
export PATH="$PATH:$HOME/Library/CloudStorage/Dropbox/flutter/bin"

# LM Studio CLI
export PATH="$PATH:$HOME/.lmstudio/bin"

# Wolfram
export PATH="/Applications/Wolfram.app/Contents/MacOS:$PATH"

# Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Claude memory worker
alias claude-mem='$HOME/.bun/bin/bun "$HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'

{{ else if $isLinux -}}
# === Linux specific settings ===

# Linuxbrew
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
fi

# Zsh tools installed by Linuxbrew
if command -v brew >/dev/null 2>&1; then
    _zsh_history_substring_search="$(brew --prefix 2>/dev/null)/share/zsh-history-substring-search/zsh-history-substring-search.zsh"
    if [ -r "$_zsh_history_substring_search" ]; then
        source "$_zsh_history_substring_search"
        # Keep the selected history entry when moving the cursor horizontally.
        bindkey '^[[A' history-substring-search-up
        bindkey '^[[B' history-substring-search-down
        bindkey '^[OA' history-substring-search-up
        bindkey '^[OB' history-substring-search-down
        bindkey '^[[D' backward-char
        bindkey '^[[C' forward-char
        bindkey '^[OD' backward-char
        bindkey '^[OC' forward-char
    fi
    unset _zsh_history_substring_search
fi
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh)"
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

{{ if eq $linuxProfile "raspberrypi" -}}
# Raspberry Pi specific settings
export OS_NAME=RaspberryPi

{{ else -}}
# Ubuntu specific settings
export OS_NAME=Linux

{{ if eq $linuxProfile "server" -}}
# Fix byobu/tmux F-keys on physical Linux console
[[ "$TERM" == "linux" ]] && export TERM=xterm-256color

# Auto-start byobu on interactive login shells, but return to zsh when byobu exits.
if [[ -o interactive && -z "$TMUX" && -z "$BYOBU_BACKEND" ]] && command -v byobu >/dev/null 2>&1; then
    byobu
fi

{{ end -}}

# Miniforge (Conda-forge) initialization
if [ -x "$HOME/miniforge3/bin/conda" ]; then
    __conda_setup="$('$HOME/miniforge3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        export PATH="$HOME/miniforge3/bin:$PATH"
    fi
    unset __conda_setup
else
    if [ -f "$HOME/miniforge3/etc/profile.d/conda.sh" ]; then
        . "$HOME/miniforge3/etc/profile.d/conda.sh"
    fi
fi

export PATH="/usr/local/cuda/bin${PATH:+:${PATH}}"
export LD_LIBRARY_PATH="/usr/local/cuda/lib64${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"

# TeX Live (user-local). Prefer stable symlink created by installer
if [ -d "$HOME/texlive/bin" ]; then
    export PATH="$HOME/texlive/bin:$PATH"
fi

{{ end -}}
{{ end -}}
