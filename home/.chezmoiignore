.DS_Store

{{- $system := "desktop" }}
{{- if eq .chezmoi.os "linux" }}
  {{- $osID := .chezmoi.osRelease.id }}
  {{- $osName := "" }}
  {{- $osPrettyName := "" }}
  {{- if hasKey .chezmoi.osRelease "name" }}
    {{- $osName = .chezmoi.osRelease.name }}
  {{- end }}
  {{- if hasKey .chezmoi.osRelease "prettyName" }}
    {{- $osPrettyName = .chezmoi.osRelease.prettyName }}
  {{- end }}
  {{- if or (eq $osID "raspbian") (contains "raspberry" (lower $osName)) (contains "raspberry" (lower $osPrettyName)) (contains "raspberrypi" .chezmoi.hostname) (contains "raspi" .chezmoi.hostname) }}
    {{- $system = "raspberrypi" }}
  {{- else }}
    {{- $system = output "sh" "-c" "if { command -v systemctl >/dev/null 2>&1 && [ \"$(systemctl get-default 2>/dev/null)\" = graphical.target ]; } || [ -d /usr/share/xsessions ] || [ -d /usr/share/wayland-sessions ] || { command -v dpkg-query >/dev/null 2>&1 && dpkg-query -W -f='${Status}\\n' ubuntu-desktop ubuntu-desktop-minimal xubuntu-desktop kubuntu-desktop lubuntu-desktop ubuntu-mate-desktop 2>/dev/null | grep -q 'install ok installed'; }; then printf desktop; else printf server; fi" }}
  {{- end }}
{{- end }}

{{ if ne .chezmoi.os "darwin" -}}
.Brewfile
.config/karabiner/**
{{ end -}}

{{ if or (eq .chezmoi.os "darwin") (eq $system "server") -}}
.config/autostart/**
.config/systemd/user/rgb-load.service
.config/systemd/user/rgb-load.timer
.local/bin/rgb_load_once.sh
.xinputrc
.xprofile
{{ end -}}

{{ if eq $system "raspberrypi" -}}
.config/autostart/**
.config/systemd/user/rgb-load.service
.config/systemd/user/rgb-load.timer
.local/bin/rgb_load_once.sh
{{ end -}}
